# PromptHub Server Configuration

# Server
PORT=3000
HOST=0.0.0.0

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Data root (SQLite DB + media files under data/, config/, logs/, backups/)
DATA_ROOT=./

# Registration
# PromptHub Web is intended for a single owner-controlled self-hosted workspace.
# Keep public registration disabled. The first administrator is created via /setup.
ALLOW_REGISTRATION=false

# Auth captcha
# Keep enabled for public or internet-reachable deployments.
# Set AUTH_CAPTCHA_ENABLED=false only for trusted private/LAN personal deployments.
AUTH_CAPTCHA_ENABLED=true

# Reverse proxy
# Keep disabled unless your reverse proxy strips client-supplied forwarding
# headers and writes trusted X-Forwarded-For / X-Real-IP values.
TRUST_PROXY_HEADERS=false

# Logging
LOG_LEVEL=info
